1 REM *** HANGMAN TEST SUITE ***
2 REM Run on C64 or compatible emulator.
3 REM Each test prints PASS or FAIL with a label.
4 REM A clean run prints only PASS lines.
5
10 DIM W$(10)
20 W$(1)="COMPUTER":W$(2)="KEYBOARD":W$(3)="MONITOR"
30 W$(4)="PRINTER":W$(5)="JOYSTICK":W$(6)="BASIC"
40 W$(7)="SPRITES":W$(8)="GRAPHICS":W$(9)="MEMORY"
50 W$(10)="COMMODORE"
55 FAILS=0

100 REM === 1. WORD LIST INTEGRITY ===
110 FOR I=1 TO 10
120   IF LEN(W$(I))=0 THEN PRINT "FAIL: EMPTY WORD AT ";I:FAILS=FAILS+1:GOTO 160
130   FOR J=1 TO LEN(W$(I))
140     C=ASC(MID$(W$(I),J,1))
145     IF C<65 OR C>90 THEN PRINT "FAIL: NON-ALPHA IN W$(";I;") POS ";J:FAILS=FAILS+1
150   NEXT J
160 NEXT I
165 PRINT "PASS: WORD LIST INTEGRITY"

200 REM === 2. BLANK INITIALISATION ===
210 FOR I=1 TO 10
220   A$=W$(I):L=LEN(A$):B$=""
230   FOR K=1 TO L:B$=B$+"-":NEXT
240   IF LEN(B$)<>L THEN PRINT "FAIL: BLANK LEN MISMATCH FOR ";A$:FAILS=FAILS+1:GOTO 280
250   FOR K=1 TO L
260     IF MID$(B$,K,1)<>"-" THEN PRINT "FAIL: NON-DASH IN BLANK FOR ";A$:FAILS=FAILS+1
270   NEXT K
280 NEXT I
285 PRINT "PASS: BLANK INITIALISATION"

300 REM === 3. LOWERCASE TO UPPERCASE CONVERSION ===
310 FOR C=97 TO 122
320   Q$=CHR$(C)
330   IF C>=97 AND C<=122 THEN Q$=CHR$(C-32)
340   EX=C-32
350   IF ASC(Q$)<>EX THEN PRINT "FAIL: LOWERCASE CONV FOR CHR$(";C;")":FAILS=FAILS+1
360 NEXT C
365 PRINT "PASS: LOWERCASE TO UPPERCASE CONVERSION"

400 REM === 4. ALREADY-GUESSED DETECTION ===
410 GS$=""
420 REM 4a: first guess of "A" â€” ALR must stay 0
430 Q$="A":GOSUB 9000
440 IF ALR<>0 THEN PRINT "FAIL: FIRST GUESS FLAGGED AS DUPLICATE":FAILS=FAILS+1
445 GS$=GS$+Q$
450 REM 4b: repeat guess of "A" â€” ALR must become 1
460 Q$="A":GOSUB 9000
470 IF ALR<>1 THEN PRINT "FAIL: DUPLICATE NOT DETECTED":FAILS=FAILS+1
480 REM 4c: new letter "B" after "A" in GS$ â€” ALR must stay 0
490 Q$="B":GOSUB 9000
500 IF ALR<>0 THEN PRINT "FAIL: FRESH LETTER FLAGGED AS DUPLICATE":FAILS=FAILS+1
505 PRINT "PASS: ALREADY-GUESSED DETECTION"

600 REM === 5. LETTER MATCHING â€” SINGLE OCCURRENCE ===
610 A$="BASIC":L=LEN(A$):B$="-----"
620 Q$="B":GOSUB 9100
630 IF FOUND<>1 THEN PRINT "FAIL: CORRECT LETTER NOT FOUND (BASIC/B)":FAILS=FAILS+1
640 IF MID$(B$,1,1)<>"B" THEN PRINT "FAIL: BOARD NOT UPDATED (BASIC/B)":FAILS=FAILS+1
645 PRINT "PASS: LETTER MATCHING - SINGLE OCCURRENCE"

650 REM === 6. LETTER MATCHING â€” REPEATED LETTERS ===
660 A$="MEMORY":L=LEN(A$):B$="------"
670 Q$="M":GOSUB 9100
680 IF FOUND<>1 THEN PRINT "FAIL: CORRECT LETTER NOT FOUND (MEMORY/M)":FAILS=FAILS+1
690 IF MID$(B$,1,1)<>"M" THEN PRINT "FAIL: FIRST M NOT REVEALED":FAILS=FAILS+1
700 IF MID$(B$,3,1)<>"M" THEN PRINT "FAIL: SECOND M NOT REVEALED":FAILS=FAILS+1
705 PRINT "PASS: LETTER MATCHING - REPEATED LETTERS (MEMORY/M)"

710 A$="COMMODORE":L=LEN(A$):B$="---------"
720 Q$="O":GOSUB 9100
730 IF FOUND<>1 THEN PRINT "FAIL: CORRECT LETTER NOT FOUND (COMMODORE/O)":FAILS=FAILS+1
740 IF MID$(B$,4,1)<>"O" THEN PRINT "FAIL: O AT POS 4 NOT REVEALED":FAILS=FAILS+1
750 IF MID$(B$,6,1)<>"O" THEN PRINT "FAIL: O AT POS 6 NOT REVEALED":FAILS=FAILS+1
760 IF MID$(B$,9,1)<>"O" THEN PRINT "FAIL: O AT POS 9 NOT REVEALED":FAILS=FAILS+1
765 PRINT "PASS: LETTER MATCHING - REPEATED LETTERS (COMMODORE/O)"

800 REM === 7. WRONG GUESS DECREMENTS G ===
810 A$="BASIC":L=LEN(A$):B$="-----":G=6
820 Q$="Z":GOSUB 9100
830 IF FOUND<>0 THEN PRINT "FAIL: Z FOUND IN BASIC":FAILS=FAILS+1
840 IF G<>5 THEN PRINT "FAIL: G NOT DECREMENTED ON WRONG GUESS":FAILS=FAILS+1
845 PRINT "PASS: WRONG GUESS DECREMENTS G"

850 REM === 8. CORRECT GUESS DOES NOT DECREMENT G ===
860 A$="BASIC":L=LEN(A$):B$="-----":G=6
870 Q$="A":GOSUB 9100
880 IF G<>6 THEN PRINT "FAIL: G CHANGED ON CORRECT GUESS":FAILS=FAILS+1
885 PRINT "PASS: CORRECT GUESS DOES NOT DECREMENT G"

900 REM === 9. WIN CONDITION ===
910 A$="BASIC":B$="BASIC"
920 IF B$=A$ THEN WIN=1 ELSE WIN=0
930 IF WIN<>1 THEN PRINT "FAIL: WIN NOT DETECTED WHEN B$=A$":FAILS=FAILS+1
935 PRINT "PASS: WIN CONDITION"

940 REM === 10. LOSE CONDITION ===
950 G=0
960 IF G=0 THEN LOSE=1 ELSE LOSE=0
970 IF LOSE<>1 THEN PRINT "FAIL: LOSE NOT DETECTED WHEN G=0":FAILS=FAILS+1
975 PRINT "PASS: LOSE CONDITION"

980 REM === 11. WIN TAKES PRECEDENCE OVER LOSE ===
990 REM Last correct letter fills board AND G happens to reach 0 simultaneously.
991 REM Win check (B$=A$) must fire before lose check (G=0).
992 A$="AB":B$="AB":G=0
993 WIN2=0:LOSE2=0
994 IF B$=A$ THEN WIN2=1
995 IF G=0 AND WIN2=0 THEN LOSE2=1
996 IF WIN2<>1 THEN PRINT "FAIL: WIN NOT DETECTED IN TIE SCENARIO":FAILS=FAILS+1
997 IF LOSE2<>0 THEN PRINT "FAIL: LOSE FIRED INSTEAD OF WIN":FAILS=FAILS+1
998 PRINT "PASS: WIN TAKES PRECEDENCE OVER LOSE"

1000 REM === 12. NON-ALPHA INPUT SHOULD NOT COST A GUESS ===
1010 REM Bug: entering "3" or "!" passes LEN check, is not found,
1010 REM and silently decrements G. Until fixed this test will FAIL.
1020 A$="BASIC":L=LEN(A$):B$="-----":G=6
1030 Q$="3"
1035 REM A fix would add: IF C<65 OR C>90 THEN PRINT "NOT A LETTER":GOTO <reprompt>
1040 VALID=0
1050 CV=ASC(Q$):IF CV>=65 AND CV<=90 THEN VALID=1
1060 IF CV>=97 AND CV<=122 THEN VALID=1
1070 IF VALID=0 THEN GOTO 1090
1080 GOSUB 9100
1090 IF G<>6 THEN PRINT "FAIL: NON-ALPHA INPUT CONSUMED A GUESS (KNOWN BUG)":FAILS=FAILS+1
1095 PRINT "PASS: NON-ALPHA INPUT DOES NOT COST A GUESS"

2000 REM === SUMMARY ===
2010 PRINT ""
2020 IF FAILS=0 THEN PRINT "ALL TESTS PASSED":GOTO 2040
2030 PRINT FAILS;" TEST(S) FAILED"
2040 END

9000 REM --- ALREADY-GUESSED CHECK SUBROUTINE ---
9005 ALR=0
9010 FOR J=1 TO LEN(GS$)
9020   IF MID$(GS$,J,1)=Q$ THEN ALR=1
9030 NEXT J
9040 RETURN

9100 REM --- LETTER MATCHING SUBROUTINE ---
9105 FOUND=0
9110 FOR I=1 TO L
9120   IF MID$(A$,I,1)=Q$ THEN MID$(B$,I,1)=Q$:FOUND=1
9130 NEXT I
9140 IF FOUND=0 THEN G=G-1
9150 RETURN
